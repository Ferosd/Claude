    {
      "id": "f1916eb5-3b7f-470b-a48f-88dd3d8ae7ff",
      "name": "Google Drive \u2014 Download KB",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        680,
        100
      ],
      "continueOnFail": true,
      "parameters": {
        "resource": "file",
        "operation": "download",
        "fileId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $env.KNOWLEDGE_BASE_FILE_ID }}"
        },
        "options": {}
      },
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "REPLACE_GDRIVE_CRED_ID",
          "name": "Google Drive account"
        }
      },
      "notes": "Downloads coremagna-knowledge-base.txt from Google Drive on every request. Set KNOWLEDGE_BASE_FILE_ID env var."
    },
    {
      "id": "0bd26a42-a511-459f-ba4f-3825dc8ae032",
      "name": "RAG Search",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        100
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Keyword-based RAG: score chunks by overlap with user message\nconst setFields = $('Set Fields').first().json;\nconst message = setFields.user_message.toLowerCase();\n\n// Knowledge base may arrive as binary data or text depending on n8n version\nlet kbText = '';\nconst driveItem = $('Google Drive \u2014 Download KB').first();\nif (driveItem.binary && driveItem.binary.data) {\n  // Convert binary buffer to text\n  kbText = Buffer.from(driveItem.binary.data.data, 'base64').toString('utf8');\n} else if (driveItem.json && driveItem.json.data) {\n  kbText = driveItem.json.data;\n} else {\n  kbText = '';\n}\n\nlet rag_context = 'No specific context found. Answer based on general Coremagna knowledge.';\n\nif (kbText.length > 20) {\n  const chunks = kbText.split('---').map(c => c.trim()).filter(c => c.length > 20);\n  const words = message.split(/\\s+/).filter(w => w.length > 2);\n\n  const scored = chunks.map(chunk => {\n    const lower = chunk.toLowerCase();\n    let score = 0;\n    words.forEach(w => { if (lower.includes(w)) score++; });\n    return { chunk, score };\n  });\n\n  scored.sort((a, b) => b.score - a.score);\n  const topChunks = scored.slice(0, 3).filter(s => s.score > 0);\n  if (topChunks.length > 0) {\n    rag_context = topChunks.map(s => s.chunk).join('\\n\\n');\n  }\n}\n\nreturn [{\n  json: {\n    rag_context,\n    user_message: setFields.user_message,\n    session_id: setFields.session_id,\n    visitor_name: setFields.visitor_name,\n    visitor_email: setFields.visitor_email,\n    page_url: setFields.page_url,\n    mode: setFields.mode,\n  }\n}];\n"
      },
      "notes": "Splits knowledge base into chunks, scores by keyword overlap, returns top 3."
    },
    {
      "id": "93a90c31-30e4-49a5-8279-689e979b53ab",
      "name": "AI Agent",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.6,
      "position": [
        1160,
        100
      ],
      "continueOnFail": true,
      "retryOnFail": true,
      "maxTries": 2,
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-4o-mini"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are Magna, Coremagna's AI assistant on coremagna.com.\n\nROLE: Help visitors understand Coremagna's AI automation services. Answer questions, explain services, provide pricing, and guide them to book a call.\n\nKNOWLEDGE BASE CONTEXT (use this to answer):\n{{ $json.rag_context }}\n\nRULES:\n- Be concise: 2-4 sentences max unless asked for detail\n- Be warm and professional\n- Always suggest booking a free call for detailed discussions: https://calendar.app.google/XDGM8XJ9zEdqugKr9\n- If you don't know something, say \"I'd recommend booking a call with Ferit to discuss that in detail\"\n- Collect lead info naturally: name, email, business type, what they need help with\n- When you have name + email + interest, set is_complete to true in your JSON response\n- Never invent features or prices not in the knowledge base\n\nRESPONSE FORMAT (strict JSON):\n{\n  \"message\": \"your response text here\",\n  \"lead_data\": {\n    \"name\": \"collected name or empty string\",\n    \"phone\": \"collected phone or empty string\",\n    \"email\": \"collected email or empty string\",\n    \"interest\": \"what they're interested in or empty string\",\n    \"viewing_date\": \"preferred call time or empty string\",\n    \"lead_score\": 0-10,\n    \"is_complete\": false\n  }\n}"
            },
            {
              "role": "user",
              "content": "={{ $json.user_message }}"
            }
          ]
        },
        "jsonOutput": true,
        "options": {
          "temperature": 0.7,
          "maxTokens": 600
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "REPLACE_OPENAI_CRED_ID",
          "name": "OpenAI account"
        }
      },
      "notes": "Updated: system prompt now includes RAG context injected before each request."
    },
    {
      "id": "1bddb6fa-5fe0-4aa9-871b-ee2ed599f578",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        100
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Extract message + lead_data from AI JSON response\nconst aiItem = $input.item;\nconst ragData = $('RAG Search').first().json;\n\nlet parsed = {};\ntry {\n  const raw = aiItem.json?.message?.content || aiItem.json?.content || '{}';\n  if (typeof raw === 'object') {\n    parsed = raw;\n  } else {\n    parsed = JSON.parse(raw);\n  }\n} catch (e) {\n  // Fallback: treat entire content as reply text\n  const fallback = aiItem.json?.message?.content || '';\n  parsed = { message: fallback, lead_data: {} };\n}\n\nconst reply = parsed.message || 'I\\'m here to help! What would you like to know?';\nconst lead = parsed.lead_data || {};\n\nreturn [{\n  json: {\n    reply,\n    lead_data: lead,\n    is_complete: Boolean(lead.is_complete),\n    session_id: ragData.session_id,\n    visitor_name: ragData.visitor_name,\n    visitor_email: ragData.visitor_email,\n    user_message: ragData.user_message,\n    page_url: ragData.page_url,\n  }\n}];\n"
      }
    },
