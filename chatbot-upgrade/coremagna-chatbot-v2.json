    {
      "id": "f040babb-afe9-4c2c-a5fb-62782047ba4a",
      "name": "Gmail \u2014 Lead Notification",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        2120,
        0
      ],
      "continueOnFail": true,
      "parameters": {
        "resource": "message",
        "operation": "send",
        "sendTo": "={{ $env.NOTIFICATION_EMAIL || 'ferit1@coremagna.com' }}",
        "subject": "=\ud83d\udd25 New lead captured: {{ $json.lead_data.name || $json.visitor_name }}",
        "emailType": "html",
        "message": "=<h2>New lead captured via chat</h2>\n<table>\n<tr><td><strong>Name:</strong></td><td>{{ $json.lead_data.name || $json.visitor_name }}</td></tr>\n<tr><td><strong>Email:</strong></td><td>{{ $json.lead_data.email || $json.visitor_email }}</td></tr>\n<tr><td><strong>Phone:</strong></td><td>{{ $json.lead_data.phone || 'N/A' }}</td></tr>\n<tr><td><strong>Interest:</strong></td><td>{{ $json.lead_data.interest }}</td></tr>\n<tr><td><strong>Score:</strong></td><td>{{ $json.lead_data.lead_score }}/10</td></tr>\n<tr><td><strong>Page:</strong></td><td>{{ $json.page_url }}</td></tr>\n</table>\n<p><a href='https://calendar.app.google/XDGM8XJ9zEdqugKr9'>Book a call with them \u2192</a></p>",
        "options": {}
      },
      "credentials": {
